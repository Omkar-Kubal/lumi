# ── Gradle ────────────────────────────────────────────────────────────────────
.gradle/
build/
**/build/

# Gradle wrapper jar is intentionally committed; ignore everything else in cache
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# ── Android Studio / IntelliJ IDEA ───────────────────────────────────────────
*.iml
.idea/
# Allow sharing run configurations with the team (uncomment if desired):
# !.idea/runConfigurations/

# ── Kotlin / KSP ─────────────────────────────────────────────────────────────
.kotlin/
# KSP-generated sources end up inside build/ (already covered above),
# but explicitly ignore the standalone kspCaches directory if it appears
kspCaches/

# ── Local / machine-specific ──────────────────────────────────────────────────
local.properties
*.local.properties

# ── Security — never commit secrets ──────────────────────────────────────────
*.jks
*.keystore
*.p12
*.pfx
keystore.properties
release.properties
google-services.json
GoogleService-Info.plist

# ── Native build artefacts ────────────────────────────────────────────────────
.externalNativeBuild/
.cxx/

# ── Captures & profiling ──────────────────────────────────────────────────────
captures/
*.hprof

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log

# ── OS generated ──────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
Thumbs.db
ehthumbs.db
Desktop.ini

# ── Claude Code tooling ───────────────────────────────────────────────────────
.claude/
